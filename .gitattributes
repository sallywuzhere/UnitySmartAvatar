*.onnx filter=lfs diff=lfs merge=lfs -text
*.bin filter=lfs diff=lfs merge=lfs -text
*.fbx filter=lfs diff=lfs merge=lfs -text

# normalize all text files to LF
* text=auto eol=lf

# unity specific
*.cs text eol=lf
*.unity text eol=lf
*.asset text eol=lf
*.meta text eol=lf
*.prefab text eol=lf
*.json text eol=lf

# binary files - never touch line endings
*.png binary
*.jpg binary
*.wav binary
*.mp3 binary
*.onnx binary
*.bin binary
*.dll binary